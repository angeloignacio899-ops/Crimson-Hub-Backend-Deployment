# Environment Variables for Production

# Railway automatically sets these - DO NOT SET MANUALLY
# PORT - Automatically set by Railway
# RAILWAY_STATIC_URL - Automatically set by Railway

# Database (Railway provides MySQL/PostgreSQL)
# For Railway MySQL:
DB_HOST=${MYSQLHOST}
DB_USER=${MYSQLUSER}
DB_PASSWORD=${MYSQLPASSWORD}
DB_NAME=${MYSQLDATABASE}
DB_PORT=${MYSQLPORT}

# For Railway PostgreSQL (if using instead):
# DATABASE_URL=${DATABASE_URL}

# JWT Secrets - Generate new ones for production
JWT_SECRET=your_super_secure_jwt_secret_here
JWT_RESET_SECRET=your_separate_reset_secret_here

# Google Auth
GOOGLE_CLIENT_ID=your_google_client_id

# Email (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@yourdomain.com

# Frontend URL (Your Vercel deployment URL)
FRONTEND_URL=https://your-vercel-app.vercel.app

# Server (Railway sets PORT automatically)
# PORT=5100